# Copy this file to .env for local dev. On Railway, set these under Variables instead.

PORT=8080

# Gemini — FREE. Get a key at https://aistudio.google.com/apikey (no card required).
# Powers script rewrite, scene breakdown, and all the AI-refine features.
GEMINI_API_KEY=

# Voice generation needs NO key — it uses Microsoft Edge's free neural voices
# (msedge-tts package) automatically. Nothing to configure here.

# Runway — the one piece that's still paid. Sign up separately at
# https://dev.runwayml.com (NOT the consumer app). Requires at least $10 in
# credits added before the key will work.
RUNWAYML_API_SECRET=

# Any random long string — protects your /jobs, /ai, and /files endpoints from strangers.
# Generate one with: openssl rand -hex 32
BACKEND_ACCESS_TOKEN=
